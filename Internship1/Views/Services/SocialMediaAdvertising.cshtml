@{
    ViewData["Title"] = "Kıbrıs Sosyal Medya Reklamı | Dijital Reklam Yönetimi";
    ViewData["MetaDescription"] = "Kıbrıs sosyal medya reklamı çözümleriyle doğru hedef kitleye ulaşın. Instagram ve Facebook reklam kampanyalarınızı performans odaklı yönetin.";
}

<section class="service-detail-hero">

    <div class="service-detail-glow service-detail-glow-primary"></div>
    <div class="service-detail-glow service-detail-glow-secondary"></div>

    <div class="site-container service-detail-hero-container">

        <div class="service-detail-content">

            <div class="section-eyebrow reveal">
                <span></span>
                SOSYAL MEDYA REKLAMI
            </div>

            <h1 class="service-detail-title reveal">
                Kıbrıs sosyal medya reklamı ile
                <span>
                    doğru kitleye doğru zamanda ulaşın.
                </span>
            </h1>

            <p class="service-detail-description reveal reveal-delay-1">
                Meta reklam kampanyalarını hedef kitle analizi, yaratıcı
                reklam içerikleri ve performans verileri doğrultusunda
                yöneterek reklam bütçenizi daha etkili kullanmanıza
                yardımcı oluyoruz.
            </p>

            <div class="service-detail-actions reveal reveal-delay-2">

                <a asp-controller="Contact"
                   asp-action="Index"
                   class="primary-link-button">
                    Reklam Projenizi Konuşalım
                    <span aria-hidden="true">↗</span>
                </a>

                <a asp-controller="Services"
                   asp-action="Index"
                   class="secondary-link-button">
                    Tüm Hizmetler
                </a>

            </div>

        </div>

        <div class="service-detail-panel reveal reveal-delay-2">

            <span class="service-detail-panel-label">
                AD PERFORMANCE SYSTEM
            </span>

            <h2>
                Hedefleme, optimizasyon ve performans odaklı reklam yönetimi.
            </h2>

            <div class="service-detail-panel-list">

                <div>
                    <span>1</span>
                    <p>Hedef kitle ve kampanya analizi</p>
                </div>

                <div>
                    <span>2</span>
                    <p>Reklam kampanyası planlama</p>
                </div>

                <div>
                    <span>3</span>
                    <p>Bütçe ve performans optimizasyonu</p>
                </div>

                <div>
                    <span>4</span>
                    <p>Sonuç analizi ve reklam raporlaması</p>
                </div>

            </div>

        </div>

    </div>

</section>
<section class="management-process-section">

    <div class="site-container management-process-container">

        <div class="management-process-heading">

            <div class="section-eyebrow reveal">
                <span></span>
                REKLAM SÜRECİMİZ
            </div>

            <h2 class="reveal">
                Reklam bütçesini
                <span>
                    ölçülebilir bir büyüme sürecine
                </span>
                dönüştürüyoruz.
            </h2>

            <p class="reveal reveal-delay-1">
                Başarılı bir sosyal medya reklam kampanyası yalnızca reklam
                yayınlamakla oluşmaz. Hedef kitleyi analiz ediyor, kampanyayı
                planlıyor ve performans verileri doğrultusunda sürekli
                geliştiriyoruz.
            </p>

        </div>

        <div class="management-process-list">

            <article class="management-process-item reveal">

                <span class="management-process-number">
                    1
                </span>

                <div class="management-process-content">

                    <span class="management-process-label">
                        ANALİZ
                    </span>

                    <h3>
                        Hedef kitlenizi ve reklam hedeflerinizi belirliyoruz.
                    </h3>

                    <p>
                        Marka hedeflerini, ürün veya hizmet yapısını ve
                        potansiyel müşteri davranışlarını değerlendirerek
                        kampanyanın temel hedefleme yapısını oluşturuyoruz.
                    </p>

                </div>

            </article>

            <article class="management-process-item reveal reveal-delay-1">

                <span class="management-process-number">
                    2
                </span>

                <div class="management-process-content">

                    <span class="management-process-label">
                        PLANLAMA
                    </span>

                    <h3>
                        Kampanya yapısını ve reklam stratejisini hazırlıyoruz.
                    </h3>

                    <p>
                        Reklam hedefini, hedef kitle gruplarını ve kampanya
                        yaklaşımını belirleyerek bütçenin daha kontrollü
                        kullanılabileceği bir reklam planı oluşturuyoruz.
                    </p>

                </div>

            </article>

            <article class="management-process-item reveal reveal-delay-2">

                <span class="management-process-number">
                    3
                </span>

                <div class="management-process-content">

                    <span class="management-process-label">
                        OPTİMİZASYON
                    </span>

                    <h3>
                        Kampanya performansını sürekli takip ediyoruz.
                    </h3>

                    <p>
                        Reklam sonuçlarını ve hedef kitle tepkilerini
                        değerlendirerek bütçe dağılımını ve kampanya
                        performansını düzenli olarak optimize ediyoruz.
                    </p>

                </div>

            </article>

            <article class="management-process-item reveal reveal-delay-3">

                <span class="management-process-number">
                    4
                </span>

                <div class="management-process-content">

                    <span class="management-process-label">
                        RAPORLAMA
                    </span>

                    <h3>
                        Sonuçları analiz ederek sonraki adımı geliştiriyoruz.
                    </h3>

                    <p>
                        Erişim, etkileşim ve kampanya sonuçlarını analiz ederek
                        reklam stratejisinin güçlü ve geliştirilmesi gereken
                        noktalarını belirliyoruz.
                    </p>

                </div>

            </article>

        </div>

    </div>

</section>
@await Html.PartialAsync(
    "_ServiceCta",
    new Internship1.Models.ServiceCtaViewModel
    {
        Label = "REKLAM PERFORMANSINIZI GELİŞTİRİN",
        Title = "Markanız için güçlü bir",
        HighlightedTitle = "sosyal medya reklam sistemi oluşturalım.",
        Description = "Reklam hedeflerinizi, hedef kitlenizi ve dijital büyüme beklentilerinizi birlikte değerlendirerek markanız için performans odaklı bir reklam süreci planlayalım.",
        PrimaryButtonText = "Reklam Projenizi Konuşalım",
        SecondaryButtonText = "Diğer Hizmetleri İncele"
    }
)