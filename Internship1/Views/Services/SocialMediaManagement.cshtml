@{
    ViewData["Title"] = "Kıbrıs Sosyal Medya Yönetimi | Profesyonel Marka Yönetimi";
    ViewData["MetaDescription"] = "Kıbrıs sosyal medya yönetimi hizmetleriyle içerik planlaması, hesap yönetimi ve marka iletişiminizi profesyonel bir stratejiyle geliştirin.";
}

<section class="service-detail-hero">

    <div class="service-detail-glow service-detail-glow-primary"></div>
    <div class="service-detail-glow service-detail-glow-secondary"></div>

    <div class="site-container service-detail-hero-container">

        <div class="service-detail-content">

            <div class="section-eyebrow reveal">
                <span></span>
                SOSYAL MEDYA YÖNETİMİ
            </div>

            <h1 class="service-detail-title reveal">
                Kıbrıs sosyal medya yönetimi ile
                <span>
                    markanızı daha görünür hale getirin.
                </span>
            </h1>

            <p class="service-detail-description reveal reveal-delay-1">
                Sosyal medya hesaplarınızı yalnızca paylaşım yapılan
                kanallar olarak değil, markanızın hedef kitlesiyle düzenli
                iletişim kurduğu profesyonel dijital alanlar olarak yönetiyoruz.
            </p>

            <div class="service-detail-actions reveal reveal-delay-2">

                <a asp-controller="Contact"
                   asp-action="Index"
                   class="primary-link-button">
                    Projenizi Konuşalım
                    <span aria-hidden="true">↗</span>
                </a>

                <a asp-controller="Services"
                   asp-action="Index"
                   class="secondary-link-button">
                    Tüm Hizmetler
                </a>

            </div>

        </div>

        <div class="service-detail-panel reveal reveal-delay-2">

            <span class="service-detail-panel-label">
                MANAGEMENT SYSTEM
            </span>

            <h2>
                Planlı, tutarlı ve ölçülebilir sosyal medya yönetimi.
            </h2>

            <div class="service-detail-panel-list">

                <div>
                    <span>1</span>
                    <p>İçerik planı oluşturma</p>
                </div>

                <div>
                    <span>2</span>
                    <p>Marka diline uygun paylaşım yönetimi</p>
                </div>

                <div>
                    <span>3</span>
                    <p>Hedef kitleyle düzenli iletişim</p>
                </div>

                <div>
                    <span>4</span>
                    <p>Performans takibi ve raporlama</p>
                </div>

            </div>

        </div>

    </div>

</section>
<section class="management-process-section">

    <div class="site-container management-process-container">

        <div class="management-process-heading">

            <div class="section-eyebrow reveal">
                <span></span>
                YÖNETİM SÜRECİMİZ
            </div>

            <h2 class="reveal">
                Sosyal medya yönetimini
                <span>
                    planlı bir dijital sürece
                </span>
                dönüştürüyoruz.
            </h2>

            <p class="reveal reveal-delay-1">
                Etkili sosyal medya yönetimi yalnızca düzenli paylaşım
                yapmaktan ibaret değildir. Markanın hedeflerini, hedef
                kitlesini ve iletişim dilini anlayarak sürdürülebilir bir
                sosyal medya sistemi oluşturuyoruz.
            </p>

        </div>

        <div class="management-process-list">

            <article class="management-process-item reveal">

                <span class="management-process-number">
                    1
                </span>

                <div class="management-process-content">

                    <span class="management-process-label">
                        ANALİZ
                    </span>

                    <h3>
                        Markanızı ve hedef kitlenizi analiz ediyoruz.
                    </h3>

                    <p>
                        Marka yapısını, sektörü, mevcut sosyal medya
                        hesaplarını ve hedef kitle davranışlarını
                        değerlendirerek yönetim sürecinin temelini oluşturuyoruz.
                    </p>

                </div>

            </article>

            <article class="management-process-item reveal reveal-delay-1">

                <span class="management-process-number">
                    2
                </span>

                <div class="management-process-content">

                    <span class="management-process-label">
                        PLANLAMA
                    </span>

                    <h3>
                        İçerik ve iletişim planını hazırlıyoruz.
                    </h3>

                    <p>
                        Paylaşım konularını, içerik türlerini ve iletişim
                        yaklaşımını marka hedefleri doğrultusunda planlayarak
                        tutarlı bir yayın düzeni oluşturuyoruz.
                    </p>

                </div>

            </article>

            <article class="management-process-item reveal reveal-delay-2">

                <span class="management-process-number">
                    3
                </span>

                <div class="management-process-content">

                    <span class="management-process-label">
                        YÖNETİM
                    </span>

                    <h3>
                        Sosyal medya iletişimini aktif olarak yönetiyoruz.
                    </h3>

                    <p>
                        İçeriklerin yayınlanmasını ve marka iletişiminin
                        sürekliliğini takip ederek sosyal medya hesaplarının
                        profesyonel bir yapıda ilerlemesini sağlıyoruz.
                    </p>

                </div>

            </article>

            <article class="management-process-item reveal reveal-delay-3">

                <span class="management-process-number">
                    4
                </span>

                <div class="management-process-content">

                    <span class="management-process-label">
                        GELİŞİM
                    </span>

                    <h3>
                        Performansı analiz ederek stratejiyi geliştiriyoruz.
                    </h3>

                    <p>
                        İçerik sonuçlarını ve kullanıcı etkileşimlerini
                        değerlendirerek sosyal medya stratejisini elde edilen
                        verilere göre sürekli iyileştiriyoruz.
                    </p>

                </div>

            </article>

        </div>

    </div>

</section>